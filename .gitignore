# Node.js
node_modules/
/.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
dist/
*.tsbuildinfo
next-env.d.ts

# プロジェクト固有の出力ファイル
scripts/output/
scripts/*.csv

# Next.js
.next/
/out/
.swc/
build/
.next/cache/

# docs/ ディレクトリ（GitHub Pages出力）
# distDir: 'docs' により、ビルド出力が直接 docs/ に生成される
# ただし docs/data/ と docs/.nojekyll は追跡対象
docs/*
!docs/.nojekyll
# docs/data/ は元データとして保持（ビルド時には public/data/ から自動コピーされる）
!docs/data/
docs/data/**
!docs/data/**/*.csv
!docs/data/**/*.md

# 環境変数ファイル
.env*.local
docs/.env*.local

# Vercel
.vercel
docs/.vercel

# テスト
/coverage

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# ログ
*.log

# その他
*.pem
